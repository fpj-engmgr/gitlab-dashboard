GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=your-gitlab-personal-access-token-here
DATABASE_URL=sqlite:///./gitlab_metrics.db
CACHE_DURATION_HOURS=6
TEAM_MEMBERS_FILE=team_members.json
# Performance: Set to False for faster loading
# Contributor stats now use activity counts instead of detailed fetching
FETCH_COMMIT_DETAILS=False
FETCH_COMMENT_DETAILS=True

# Review Response Time Metrics
# Set to False to disable review response metrics (saves ~8 minutes on refresh)
# Requires FETCH_COMMENT_DETAILS=True to work
ENABLE_REVIEW_METRICS=True

# Stale MR Detection
# MRs open longer than this many days are highlighted as stale
STALE_MR_DAYS=14

# Server Configuration
# Port to run the dashboard on (default: 8000)
PORT=8000
